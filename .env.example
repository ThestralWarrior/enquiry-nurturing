# LeadPilot — AI configuration
# Copy to .env.local to override. Sensible defaults are baked in, so this is optional.

# --- Groq (optional) ---
# If GROQ_API_KEY is set, ALL chat + analysis calls route to Groq's cloud API
# instead of local Ollama. Trades "fully local/offline" for a genuinely more
# coherent model (70B) and no CPU/GPU ceiling. Get a key at console.groq.com.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_ANALYZE_MODEL=llama-3.3-70b-versatile

# --- Local Ollama (used only when GROQ_API_KEY is unset) ---
# Where the Ollama server is listening.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# The local model used for the live buyer-facing chat. Keep this small/fast —
# every turn is on the buyer's critical path.
# Pull it once with:  ollama pull qwen2.5:1.5b
OLLAMA_MODEL=qwen2.5:1.5b

# The model used for the one-time lead-analysis step (qualification + summary
# + suggested reply). This runs in the background, not on the buyer's screen,
# so a bigger/slower model is a free upgrade here if it improves quality.
# Defaults to OLLAMA_MODEL if unset. Pull it once with:  ollama pull qwen2.5:3b
# OLLAMA_ANALYZE_MODEL=qwen2.5:3b
